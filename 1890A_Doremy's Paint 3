#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin>>t;
    for(int i=0;i<t;i++){
        int n;
        cin>>n;
        int arr[n];
        for(int j=0;j<n;j++){
            cin>>arr[j];
        }
        if(n==2){
            cout<<"YES"<<endl;
            continue;
        }
        unordered_map<int,int>mp;
        for(int j=0;j<n;j++){
            mp[arr[j]]++;
        }
        if(mp.size()>2){
            cout<<"NO"<<endl;
        }
        else if(mp.size()==1) {
            cout<<"YES"<<endl;
        }
        else if(mp.size()==2){
            auto it=mp.begin();
            int a=it->second;
            it++;
            int b=it->second;
            if(abs(a-b)<=1) {
                cout<<"YES"<<endl;
            }
            else{
                cout<<"NO"<<endl;
            }
        }
        
        
        
        
    }
}
